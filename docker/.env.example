# =============================================
# 环境变量配置示例
# 复制此文件为 .env 并修改对应值
# =============================================

# MySQL 配置
MYSQL_ROOT_PASSWORD=your_strong_root_password
MYSQL_DATABASE=blog
MYSQL_USER=blog_user
MYSQL_PASSWORD=your_blog_password

# JWT 密钥（必须修改！长度 >= 32 字符）
JWT_SECRET=YOUR_VERY_LONG_AND_SECURE_RANDOM_SECRET_KEY_HERE

# 初始管理员密码
ADMIN_INIT_PASSWORD=your_admin_password

# 生产环境前端域名（用于 CORS）
# CORS_ALLOWED_ORIGINS=https://www.weihanyinian.cn
