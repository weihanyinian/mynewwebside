# 复制为 .env.local 后填写（勿提交密钥）

# ICP / 公安备案（可选，也可写死在页脚默认值）
# VITE_PUBLIC_ICP_NO=桂ICP备2025060137号-2
# VITE_PUBLIC_ICP_URL=https://beian.miit.gov.cn/
# VITE_PUBLIC_PSB_NO=
# VITE_PUBLIC_PSB_URL=#

# 仓库地址（页脚徽章）
# VITE_PUBLIC_GITHUB_REPO=https://github.com/weihanyinian/mynewwebside

# Umami 自托管统计：https://github.com/umami-software/umami
# 部署后在 Umami 创建站点，将 script 地址与 website id 填入：
# VITE_UMAMI_SRC=https://your-umami.example.com/script.js
# VITE_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 公开分享页（iframe 用）与管理员后台入口（仅管理员可见按钮）
# VITE_UMAMI_SHARE_URL=https://your-umami.example.com/share/xxxxx
# VITE_UMAMI_DASHBOARD_URL=https://your-umami.example.com/
